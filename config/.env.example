# =============================================================================
# Deputy Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# --- GitHub MCP ---
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_username
GITHUB_REPO_NAME=deputy

# --- LLM Providers (Free Tiers) ---
# Groq: https://console.groq.com (no credit card required)
GROQ_API_KEY=your_groq_key_here

# Google Gemini: https://ai.google.dev (no credit card required)
GOOGLE_API_KEY=your_google_key_here

# OpenRouter: https://openrouter.ai (no credit card required)
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Search APIs (Free Tiers) ---
# Tavily: https://tavily.com (1K free/month, no credit card)
TAVILY_API_KEY=your_tavily_key_here

# Brave Search: https://brave.com/search/api (~1K free/month, credit card required)
BRAVE_API_KEY=your_brave_key_here

# --- Ollama (Local, No API Key) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- SearXNG (Self-Hosted, No API Key) ---
SEARXNG_URL=http://localhost:8080

# --- LangSmith (Optional, 5K free traces/month) ---
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING=false

# --- Model Configuration ---
# CEO/Orchestrator: Strong model for planning
CEO_MODEL=groq/llama-3.3-70b-versatile

# C-Suite/Managers: Mid-tier for coordination
MANAGER_MODEL=groq/qwen/qwen3-32b

# Workers: Fast model for execution
WORKER_MODEL=groq/llama-3.1-8b-instant

# Embeddings: Local or cloud
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=mxbai-embed-large

# --- Google Workspace (EA Agent) ---
# Google Cloud Console: https://console.cloud.google.com
# 1. Create project → Enable Gmail API + Calendar API
# 2. Create OAuth 2.0 credentials (Desktop app)
# 3. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# --- ntfy.sh Push Notifications (EA Agent) ---
# 1. Install ntfy.sh app on your phone
# 2. Open app → Add subscription → Enter a unique topic name
# 3. Copy that topic name below
NTFY_TOPIC=your_unique_topic_name
NTFY_SERVER=https://ntfy.sh

# --- Platform Configuration ---
# Fiverr (if automating)
FIVERR_USERNAME=

# Upwork (if automating)
UPWORK_USERNAME=

# Outlier (if automating)
OUTLIER_EMAIL=

# --- Email Configuration ---
# Mailgun free tier: 100 emails/day
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
